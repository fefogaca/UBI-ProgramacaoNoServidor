# =============================================================================
# GREENHERB — exemplo de ambiente (.env)
# Copiar para `.env` e ajustar:  cp .env.example .env
# O ficheiro `.env` NÃO vai para o Git (está em .gitignore).
# =============================================================================

# Ambiente de execução (development | production | test)
NODE_ENV=development

# Porta HTTP da API Express
PORT=3000

# MongoDB connection string (Mongoose).
# O último segmento após '/' é o nome da base de dados (ex.: greenherb).
#
# Com Docker Compose deste projeto (porta host 27018 → 27017 no contentor):
MONGODB_URI=mongodb://127.0.0.1:27018/greenherb
#
# Sem Docker (Mongo instalado localmente na porta default):
# MONGODB_URI=mongodb://127.0.0.1:27017/greenherb

# Opcional: tempo máximo para o Mongoose encontrar replicaset/servidor (ms)
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
